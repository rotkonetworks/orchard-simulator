# Rust build cache. Regenerable from `cargo build`. Hundreds of MB
# to GB depending on feature combination.
target/

# Generated wasm-bindgen output. Regenerated by `build-wasm.sh` and
# `build-wasm-parallel.sh`. Kept out of git because the WASM blob is
# multi-megabyte and changes on every build.
web/pkg/
web/pkg-parallel/

# Editor / OS noise.
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Backup files (keep nothing in tree under `*-v1` etc.).
*-v1.html
*-v1.css

# Cargo.lock.orchard-seed is a legacy artifact from the initial
# orchard checkout; not part of the build.
Cargo.lock.orchard-seed
